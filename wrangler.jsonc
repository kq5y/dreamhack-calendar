{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dreamhack-calendar",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-24",
  "assets": {
    "directory": "public"
  },
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    }
  },
  "routes": [
    {
      "pattern": "dhctf-cal.kq5.jp",
      "custom_domain": true
    }
  ]
}
